{
  "permissions": {
    "allow": [
      "Read(/Users/danporter/.claude/**)",
      "Bash(*)",
      "Write(*)",
      "Read(//Users/danporter/**)",
      "WebFetch(domain:musopen.org)",
      "WebSearch",
      "WebFetch(domain:api.github.com)"
    ],
    "additionalDirectories": [
      "/Users/danporter/.claude",
      "/Users/danporter",
      "/Users/danporter/Desktop/Group Chat Knows/.claude"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/dangerous-actions-blocker.sh \"$CLAUDE_TOOL_INPUT_COMMAND\""
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/secrets-scanner.sh \"$CLAUDE_TOOL_INPUT_COMMAND\""
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/secrets-scanner.sh \"$CLAUDE_TOOL_INPUT_CONTENT\""
          }
        ]
      }
    ]
  }
}
