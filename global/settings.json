{
  "env": {
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80"
  },
  "permissions": {
    "allow": [
      "Read(/Users/danporter/.claude/**)",
      "Bash(*)",
      "Write(*)",
      "Read(//Users/danporter/**)",
      "WebFetch(domain:musopen.org)",
      "WebSearch",
      "WebFetch(domain:api.github.com)",
      "Bash(cp ~/.claude/CLAUDE.md /Users/danporter/Desktop/claude-os/global/CLAUDE.md)",
      "Bash(git add:*)",
      "Bash(git commit -m ':*)",
      "Bash(git push:*)"
    ],
    "additionalDirectories": [
      "/Users/danporter/.claude",
      "/Users/danporter",
      "/Users/danporter/Desktop/Group Chat Knows/.claude",
      "/Users/danporter/Desktop/Last Take Brand New/.claude"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/dangerous-actions-blocker.sh \"$CLAUDE_TOOL_INPUT_COMMAND\""
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/secrets-scanner.sh \"$CLAUDE_TOOL_INPUT_COMMAND\""
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/secrets-scanner.sh \"$CLAUDE_TOOL_INPUT_CONTENT\""
          }
        ]
      }
    ]
  }
}
